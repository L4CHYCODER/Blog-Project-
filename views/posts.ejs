<%- include('partials/header') %>
    <%- include('partials/navbar') %>

        <main>
            <h1>Showing
                <%=posts.length%> posts
            </h1>
            <% posts.forEach(post=> { %>
                <div class="post-card">
                    <h2>
                        <a href="/posts/<%=post.id %>">
                            <%=post.title %>
                        </a>
                    </h2>
                    <p>
                        <%= post.content.substring(0, 100) %>...
                    </p>
                    <p class="post-meta">
                        <%=post.date %> |by <%=post.author %>
                    </p>
                </div>
                <% }) %>
        </main>

        <%- include('partials/footer') %>