<%- include('partials/header') %>
    <%- include('partials/navbar') %>

        <main>
            <h1>
                <%=post.title %>
            </h1>
            <h2>by
                <%=post.author%>
            </h2>
            <p>
                <%=post.date%>
            </p>
            <p>
                <%=post.content%>
            </p>


            <form action="/posts/<%= post.id %>/delete" method="POST" style="display: inline;">
                <button type="submit" class="btn-delete">Delete Post</button>
            </form>

            <a href="/posts/<%= post.id %>/edit" class="btn">Edit Post</a>
            <a href="/posts" class="btn">Back to Blog</a>

        </main>

        <%- include('partials/footer') %>